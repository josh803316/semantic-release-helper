{
  "name": "@josh803316/semantic-release-helper",
  "version": "0.0.0-semantically-released",
  "description": "Shared emantic release configuration file",
  "main": "release.config.js",
  "files": [
    "release.config.js",
    "ci/"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/josh803316/semantic-release-helper.git"
  },
  "keywords": [
    "release",
    "semantic-release",
    "semantic-release-helper"
  ],
  "author": "Josh Nisenson <josh803316@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/josh803316/semantic-release-helper/issues"
  },
  "homepage": "https://github.com/josh803316/semantic-release-helper#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "semantic-release": "^25.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.1.0"
  },
  "devDependencies": {
  },
  "prettier": {
    "printWidth": 120,
    "trailingComma": "es5"
  },
  "xo": {
    "prettier": true,
    "space": true
  }
